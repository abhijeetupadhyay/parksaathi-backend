{
  "openapi": "3.1.0",
  "info": {
    "title": "ParkSaathi API",
    "version": "v1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/parking/v1/new": {
      "post": {
        "tags": [
          "parking-controller"
        ],
        "operationId": "createParking",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddParkingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CreateParkingResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/v1/verify-otp": {
      "post": {
        "tags": [
          "auth-controller"
        ],
        "operationId": "verifyOtp",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyOtpRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/auth/v1/signup": {
      "post": {
        "tags": [
          "auth-controller"
        ],
        "operationId": "signup",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/auth/v1/signout": {
      "post": {
        "tags": [
          "auth-controller"
        ],
        "operationId": "signOut",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/auth/v1/send-otp": {
      "post": {
        "tags": [
          "auth-controller"
        ],
        "operationId": "sendOtp",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendOtpRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/auth/v1/refresh": {
      "post": {
        "tags": [
          "auth-controller"
        ],
        "operationId": "refreshToken",
        "parameters": [
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/parking/v1/nearby": {
      "get": {
        "tags": [
          "parking-controller"
        ],
        "operationId": "getNearbyParkingSpots",
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "radiusKm",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double",
              "default": 3
            }
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ParkingDetailsResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/parking/v1/detail/{parkingId}": {
      "get": {
        "tags": [
          "parking-controller"
        ],
        "operationId": "getParkingDetail",
        "parameters": [
          {
            "name": "parkingId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-device"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-correlation-id"
          },
          {
            "$ref": "#/components/parameters/x-parksaathi-version"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ParkingDetailsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddParkingRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "emergencyContact": {
            "type": "string"
          },
          "isApprovalRequired": {
            "type": "boolean"
          },
          "address": {
            "$ref": "#/components/schemas/AddressDto"
          },
          "availability": {
            "$ref": "#/components/schemas/AvailabilityDto"
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "vehicleConfigs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VehicleConfigDto"
            }
          },
          "imageUrls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AddressDto": {
        "type": "object",
        "properties": {
          "addressLine1": {
            "type": "string"
          },
          "addressLine2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          }
        }
      },
      "AvailabilityDto": {
        "type": "object",
        "properties": {
          "isOpen24Hours": {
            "type": "boolean"
          },
          "startTime": {
            "$ref": "#/components/schemas/LocalTime"
          },
          "endTime": {
            "$ref": "#/components/schemas/LocalTime"
          },
          "adStartDate": {
            "type": "string",
            "format": "date"
          },
          "adEndDate": {
            "type": "string",
            "format": "date"
          },
          "days": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "MON",
                "TUE",
                "WED",
                "THU",
                "FRI",
                "SAT",
                "SUN"
              ]
            },
            "uniqueItems": true
          }
        }
      },
      "LocalTime": {
        "type": "object",
        "properties": {
          "hour": {
            "type": "integer",
            "format": "int32"
          },
          "minute": {
            "type": "integer",
            "format": "int32"
          },
          "second": {
            "type": "integer",
            "format": "int32"
          },
          "nano": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "VehicleConfigDto": {
        "type": "object",
        "properties": {
          "vehicleTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "maxCapacity": {
            "type": "integer",
            "format": "int32"
          },
          "hourlyRate": {
            "type": "number"
          },
          "dailyRate": {
            "type": "number"
          },
          "weeklyRate": {
            "type": "number"
          },
          "monthlyRate": {
            "type": "number"
          }
        }
      },
      "CreateParkingResponse": {
        "type": "object",
        "properties": {
          "parkingId": {
            "type": "integer",
            "format": "int64"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "VerifyOtpRequest": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          },
          "otp": {
            "type": "string"
          }
        },
        "required": [
          "otp",
          "phone"
        ]
      },
      "SignupRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "aadhar": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "SendOtpRequest": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          }
        },
        "required": [
          "phone"
        ]
      },
      "ParkingDetailsResponse": {
        "type": "object",
        "properties": {
          "parkingInfo": {
            "$ref": "#/components/schemas/ParkingInfo"
          },
          "pricingAndCapacityInfo": {
            "$ref": "#/components/schemas/PricingAndCapacityInfo"
          },
          "ratingInfo": {
            "$ref": "#/components/schemas/RatingInfo"
          },
          "availabilityInfo": {
            "$ref": "#/components/schemas/AvailabilityDto"
          },
          "owner": {
            "$ref": "#/components/schemas/ParkingOwner"
          }
        }
      },
      "ParkingInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "emergencyContact": {
            "type": "string"
          },
          "isApprovalRequired": {
            "type": "boolean"
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      },
      "ParkingOwner": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "aadhar": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "PricingAndCapacityInfo": {
        "type": "object",
        "properties": {
          "vehicleConfigs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VehicleConfigWithTypeNameDto"
            },
            "uniqueItems": true
          }
        }
      },
      "RatingInfo": {
        "type": "object",
        "properties": {
          "rating": {
            "type": "number",
            "format": "double"
          },
          "ratingCount": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "VehicleConfigWithTypeNameDto": {
        "type": "object",
        "properties": {
          "vehicleType": {
            "type": "string"
          },
          "maxCapacity": {
            "type": "integer",
            "format": "int32"
          },
          "hourlyRate": {
            "type": "number"
          },
          "dailyRate": {
            "type": "number"
          },
          "weeklyRate": {
            "type": "number"
          },
          "monthlyRate": {
            "type": "number"
          }
        }
      }
    },
    "parameters": {
      "x-parksaathi-device": {
        "name": "x-parksaathi-device",
        "in": "header",
        "description": "Device type (mobile/web)",
        "required": true,
        "schema": {
          "type": "string",
          "enum": [
            "mobile",
            "web"
          ]
        }
      },
      "x-parksaathi-correlation-id": {
        "name": "x-parksaathi-correlation-id",
        "in": "header",
        "description": "Correlation ID (UUID)",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "x-parksaathi-version": {
        "name": "x-parksaathi-version",
        "in": "header",
        "description": "API Version (1.0.0)",
        "required": true,
        "schema": {
          "type": "string",
          "default": "1.0.0"
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "name": "bearerAuth",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}