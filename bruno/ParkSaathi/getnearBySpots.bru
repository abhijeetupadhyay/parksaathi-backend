meta {
  name: getnearBySpots
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/parking/v1/nearby?latitude=28.6139&longitude=77.2090&radiusKm=3.0
  body: none
  auth: inherit
}

params:query {
  latitude: 28.6139
  longitude: 77.2090
  radiusKm: 3.0
}

headers {
  x-parksaathi-device: mobile
  x-parksaathi-correlation-id: {{correlationId}}
  x-parksaathi-version: 1.0.0
}

settings {
  encodeUrl: true
  timeout: 0
}
